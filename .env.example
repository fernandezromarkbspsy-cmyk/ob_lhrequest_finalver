APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8080
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
RATE_LIMIT_PER_MINUTE=120

# Supabase Postgres free tier
DATABASE_URL=postgres://user:password@db.project-ref.supabase.co:5432/postgres?sslmode=require

# React frontend build server
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
FRONTEND_DIR=frontend-react/dist
FRONTEND_API_URL=http://127.0.0.1:8080

# Optional free-tier integrations from the guide
CLERK_SECRET_KEY=
RESEND_API_KEY=
POSTHOG_API_KEY=
SENTRY_DSN=
